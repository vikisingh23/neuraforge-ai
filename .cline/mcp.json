{
  "mcpServers": {
    "swagger-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "swagger-mcp"
      ]
    },
    "openapi-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "openapi-mcp-server"
      ]
    },
    "sonarqube-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "sonarqube-mcp-server"
      ]
    },
    "playwright-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ]
    },
    "mui-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "@mui/mcp@latest"
      ]
    },
    "a11y-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "a11y-mcp"
      ]
    },
    "reactbits-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "reactbits-dev-mcp-server"
      ]
    },
    "figma-devmode": {
      "url": "https://mcp.figma.com/mcp",
      "type": "http"
    },
    "expo-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "expo-mcp"
      ]
    },
    "cali-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "cali-mcp-server"
      ]
    },
    "gluestack-ui-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "gluestack-ui-mcp-server"
      ]
    },
    "dart-mcp-server": {
      "command": "dart",
      "args": [
        "mcp-server"
      ]
    },
    "flutter-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "flutter-mcp"
      ]
    },
    "remotion-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "@remotion/mcp@latest"
      ]
    },
    "ffmpeg-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "ffmpeg-mcp"
      ]
    },
    "media-processor": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-media-processor"
      ]
    },
    "short-video-maker": {
      "command": "npx",
      "args": [
        "-y",
        "short-video-maker"
      ],
      "env": {
        "PEXELS_API_KEY": "${PEXELS_API_KEY}"
      }
    },
    "github-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "memory-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ]
    },
    "graphify": {
      "command": "python3",
      "args": [
        "-m",
        "graphify.serve",
        "graphify-out/graph.json"
      ],
      "_note": "Optional. Install: pip install graphifyy && graphify install. Build graph: /graphify ."
    },
    "neuraforge-office-pptx": {
      "command": "npx",
      "args": [
        "-y",
        "@neuraforge/office-mcp",
        "--pptx"
      ]
    },
    "neuraforge-office-docx": {
      "command": "npx",
      "args": [
        "-y",
        "@neuraforge/office-mcp",
        "--docx"
      ]
    },
    "neuraforge-office-xlsx": {
      "command": "npx",
      "args": [
        "-y",
        "@neuraforge/office-mcp",
        "--xlsx"
      ]
    },
    "neuraforge-loadtest": {
      "command": "npx",
      "args": [
        "-y",
        "@neuraforge/loadtest-mcp"
      ]
    }
  }
}